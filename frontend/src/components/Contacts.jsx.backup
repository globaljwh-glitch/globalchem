import React, { useState, useEffect } from 'react';
import axiosInstance from '../Axios';

function Contacts() {
   const [formData, setFormData] = useState({
      first_name: '',
      last_name: '',
      email: '',
      phone: '',
      company: '',
      address: '',
      city: '',
      state: '',
      zipcode: '',
      country: '',
      application: '',
      interests: '',
      final_app: '',
      captcha_input: ''
   });

   const [errors, setErrors] = useState({});
   const [status, setStatus] = useState('');
   const [captcha, setCaptcha] = useState({ image: "", token: "" });
   const [captchaInput, setCaptchaInput] = useState("");
   const [showOtpModal, setShowOtpModal] = useState(false);
   const [otp, setOtp] = useState("");
   const [otpError, setOtpError] = useState("");
   const [submitting, setSubmitting] = useState(false);

   useEffect(() => {
      refreshCaptcha();
   }, []);

   const refreshCaptcha = async () => {
      const res = await axiosInstance.get("/api/captcha");
      setCaptcha(res.data);
   };

   const handleChange = (e) => {
      const { name, value } = e.target;
      setFormData(prev => ({
         ...prev,
         [name]: value
      }));
   };

   const handleSubmit = async (e) => {
      e.preventDefault();

      const newErrors = {};
      if (!formData.first_name.trim()) newErrors.first_name = 'First name is required';
      if (!formData.last_name.trim()) newErrors.last_name = 'Last name is required';
      if (!formData.email.trim()) newErrors.email = 'Email is required';
      if (!formData.phone.trim()) newErrors.phone = 'Phone number is required';
      if (!formData.company.trim()) newErrors.company = 'Company name is required';
      if (!formData.address.trim()) newErrors.address = 'Street address is required';
      if (!formData.city.trim()) newErrors.city = 'City is required';
      if (!formData.state.trim()) newErrors.state = 'State is required';
      if (!formData.zipcode.trim()) newErrors.zipcode = 'Zip Code is required';
      if (!formData.country.trim()) newErrors.country = 'Country is required';
      if (!formData.application.trim()) newErrors.application = 'Application is required';
      if (!formData.interests.trim()) newErrors.interests = 'What products are you interested in?';
      if (!formData.final_app.trim()) newErrors.final_app = 'Final application is required';
      if (!captchaInput.trim()) newErrors.captcha_input = 'Captcha is required';

      if (Object.keys(newErrors).length > 0) {
         setErrors(newErrors);
         return;
      }

      setErrors({});
      setStatus('Sending OTP...');
      setSubmitting(true);

      try {
         await axiosInstance.get('/sanctum/csrf-cookie');

         const postData = {
            ...formData,
            captcha_input: captchaInput,
            captcha_token: captcha.token
          };

         const response = await axiosInstance.post('/api/contact-us', postData);

         if (response.data.success) {
            setStatus(response.data.message);
            setShowOtpModal(true);
         } else {
            setStatus(response.data.message);
            refreshCaptcha();
         }

      } catch (error) {
         setStatus("Failed to send OTP.");
         refreshCaptcha();
      } finally {
         setSubmitting(false);
      }
   };

   const verifyOtpAndSave = async () => {
      if (!otp.trim()) {
         setOtpError("OTP is required.");
         return;
      }
      setOtpError("");
      setStatus("Verifying OTP...");

      try {
         await axiosInstance.get('/sanctum/csrf-cookie');

         const res = await axiosInstance.post('/api/verify-contact-otp', {
            email: formData.email,
            otp: otp
         });

         if (res.data.success) {
            setStatus(res.data.message);

            setFormData({
               first_name: '',
               last_name: '',
               email: '',
               phone: '',
               company: '',
               address: '',
               city: '',
               state: '',
               zipcode: '',
               country: '',
               application: '',
               interests: '',
               final_app: '',
            });

            setCaptchaInput('');
            refreshCaptcha();
            setShowOtpModal(false);
            setOtp('');
         } else {
            setOtpError(res.data.message);
         }

      } catch (error) {
         setOtpError("Failed to verify OTP.");
      }
   };

   return (
      <div className="row">
         <div className="col-lg-9 m-auto">
            <div className="formBlockOuter mt-5">
               {status && <div className="alert alert-info mt-3">{status}</div>}
               <form onSubmit={handleSubmit}>
                  <div className="row">
                     {/* existing form fields exactly as you had them */}
                     {/* DO NOT REMOVE OR ALTER THESE */}
                     {/* your existing form code starts here */}

                     {/* First Name */}
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>First Name <span>*</span></label>
                           <input type="text" name="first_name" value={formData.first_name} onChange={handleChange} className="form-control" />
                           {errors.first_name && <span style={{ color: 'red' }}>{errors.first_name}</span>}
                        </div>
                     </div>

                     {/* Last Name */}
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>Last Name <span>*</span></label>
                           <input type="text" name="last_name" value={formData.last_name} onChange={handleChange} className="form-control" />
                           {errors.last_name && <span style={{ color: 'red' }}>{errors.last_name}</span>}
                        </div>
                     </div>

                     {/* rest of your form fields continue untouched */}

                     {/* Email */}
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>Email Address <span>*</span></label>
                           <input type="email" name="email" value={formData.email} onChange={handleChange} className="form-control" />
                           {errors.email && <span style={{ color: 'red' }}>{errors.email}</span>}
                        </div>
                     </div>

                     {/* Phone */}
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>Phone Number <span>*</span></label>
                           <input type="text" name="phone" value={formData.phone} onChange={handleChange} className="form-control" />
                           {errors.phone && <span style={{ color: 'red' }}>{errors.phone}</span>}
                        </div>
                     </div>

                     <div className="col-md-6">
                        <div className="form-group">
                           <label>Company Name <span>*</span></label>
                           <input type="text" name="company" value={formData.company} onChange={handleChange} className="form-control" />
                           {errors.company && <span style={{ color: 'red' }}>{errors.company}</span>}
                        </div>
                     </div>
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>Street Address <span>*</span></label>
                           <input type="text" name="address" value={formData.address} onChange={handleChange} className="form-control" />
                           {errors.address && <span style={{ color: 'red' }}>{errors.address}</span>}

                        </div>
                     </div>
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>City <span>*</span></label>
                           <input type="text" name="city" value={formData.city} onChange={handleChange} className="form-control" />
                           {errors.city && <span style={{ color: 'red' }}>{errors.city}</span>}
                        </div>
                     </div>
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>State <span>*</span></label>
                           <input type="text" name="state" value={formData.state} onChange={handleChange} className="form-control" />
                           {errors.state && <span style={{ color: 'red' }}>{errors.state}</span>}
                        </div>
                     </div>
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>Zip Code <span>*</span></label>
                           <input type="text" name="zipcode" value={formData.zipcode} onChange={handleChange} className="form-control" />
                           {errors.zipcode && <span style={{ color: 'red' }}>{errors.zipcode}</span>}
                        </div>
                     </div>
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>Country <span>*</span></label>
                           <input type="text" name="country" value={formData.country} onChange={handleChange} className="form-control" />
                           {errors.country && <span style={{ color: 'red' }}>{errors.country}</span>}

                        </div>
                     </div>
                     <div className="col-md-12">
                        <label>Application and Use of Product <span>*</span></label>

                        <select name="application" className="form-control" value={formData.reason} onChange={handleChange}>
                           <option value="">--Select Application--</option>
                           <option value="Personal Care / Cosmetic">Personal Care / Cosmetic</option>
                           <option value="Food and Beverage">Food and Beverage</option>
                           <option value="Pharmaceutical">Pharmaceutical</option>
                           <option value="Flavor and Fragrance">Flavor and Fragrance</option>
                           <option value="Animal Health &amp; Nutrition">Animal Health &amp; Nutrition</option>
                           <option value="Sport Nutrition">Sport Nutrition</option>
                           <option value="Industrial">Industrial</option>
                        </select>
                        {errors.application && <span style={{ color: 'red' }}>{errors.application}</span>}

                     </div>
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>What products are you interested in? <span>*</span></label>
                           <textarea
                              name="interests"
                              value={formData.interests}
                              onChange={handleChange}
                              rows="9" className="form-control" />
                           {errors.interests && <span style={{ color: 'red' }}>{errors.interests}</span>}

                        </div>
                     </div>
                     <div className="col-md-6">
                        <div className="form-group">
                           <label>Final application? <span>*</span></label>
                           <textarea
                              name="final_app"
                              value={formData.final_app}
                              onChange={handleChange}
                              rows="9" className="form-control" />
                           {errors.final_app && <span style={{ color: 'red' }}>{errors.final_app}</span>}

                        </div>
                     </div>

                     {/* CAPTCHA */}
                     <div className="row">
                        <div className="col-md-2">
                           <img src={captcha.image} alt="CAPTCHA" />
                           <button type="button" onClick={() => refreshCaptcha()}>↻</button>
                        </div>
                        <div className="col-md-4">
                           <input
                              className="form-control"
                              type="text"
                              name="captcha_input"
                              value={captchaInput}
                              onChange={e => setCaptchaInput(e.target.value)}
                              placeholder="Enter CAPTCHA"
                           />
                           {errors.captcha_input && <span style={{ color: 'red' }}>{errors.captcha_input}</span>}
                        </div>
                     </div>

                     {/* Submit */}
                     <div className="col-md-12">
                        <div className="form-group">
                           <div className="text-end">
                              <button type="submit" className="wpcf7-form-control wpcf7-submit btn btn-primary btn-lg btn-block customBtn01 d-inline-block" disabled={submitting}>
                                 {submitting ? 'Sending...' : 'SUBMIT'}
                              </button>
                           </div>
                        </div>
                     </div>
                  </div>
               </form>

               {/* OTP Modal */}
               {showOtpModal && (
                  <div className="otp-modal" style={{
                     position: 'fixed', top: 0, left: 0, width: '100%', height: '100%',
                     background: 'rgba(0,0,0,0.6)', display: 'flex', alignItems: 'center', justifyContent: 'center'
                  }}>
                     <div style={{ background: '#fff', padding: '20px', maxWidth: '400px', borderRadius: '8px' }}>
                        <h5>Enter OTP sent to your email</h5>
                        <input
                           type="text"
                           value={otp}
                           onChange={e => setOtp(e.target.value)}
                           className="form-control my-2"
                           placeholder="Enter 6 digit OTP"
                        />
                        {otpError && <div style={{ color: 'red' }}>{otpError}</div>}
                        <button className="btn btn-primary btn-block" onClick={verifyOtpAndSave}>Verify & Submit</button>
                     </div>
                  </div>

               )}
            </div>

         </div>
      </div>
   );
}

export default Contacts;
